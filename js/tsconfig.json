{
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "es2024",
        "types": [],
        "lib": [
            "DOM",
            "ES2024"
        ],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "strict": true,
    }
}
